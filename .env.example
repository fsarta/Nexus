// Nexus: Environment configuration
// Copy to .env and fill in your values

// ============================================================
// DATABASE
// ============================================================
COCKROACHDB_URL=postgresql://nexus_app@localhost:26257/nexus?sslmode=disable
REDIS_URL=redis://localhost:6379/0
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexus_dev_password
ELASTICSEARCH_URL=http://localhost:9200
MONGODB_URL=mongodb://localhost:27017/nexus_media

// ============================================================
// AUTH
// ============================================================
JWT_SECRET=dev-secret-change-in-production-32chars-minimum!!
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

// ============================================================
// SERVICES
// ============================================================
USER_SERVICE_PORT=8080
FEED_SERVICE_PORT=8081
AI_SERVICE_PORT=8082

// ============================================================
// FRONTEND
// ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_APP_NAME=Nexus
